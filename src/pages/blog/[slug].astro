---
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, getAllPosts, getPostBySlug } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const post = await getPostBySlug(Astro.params.slug || '');

if (!post) {
  return Astro.redirect('/404.html');
}

const html = marked.parse(post.body, {
  async: false,
  gfm: true,
  breaks: false,
});
---

<BaseLayout title={post.title} description={post.excerpt}>
  <article class="article">
    <header class="article-header">
      <a class="back-link" href="/">← 返回文章列表</a>
      <div class="article-meta">
        <time datetime={post.date.toISOString()}>{formatDate(post.date)}</time>
        <span>{post.author}</span>
      </div>
      <h1>{post.title}</h1>
      {post.subtitle && <p>{post.subtitle}</p>}
      {post.tags.length > 0 && (
        <div class="tag-list" aria-label="Tags">
          {post.tags.map((tag) => <span>{tag}</span>)}
        </div>
      )}
    </header>
    <div class="prose" set:html={html} />
  </article>
</BaseLayout>

<script>
  document.querySelectorAll('.prose pre').forEach((pre) => {
    const btn = document.createElement('button');
    btn.className = 'code-copy';
    btn.type = 'button';
    btn.setAttribute('aria-label', '复制代码');
    btn.innerHTML =
      '<svg class="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>' +
      '<svg class="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
    btn.addEventListener('click', () => {
      const code = pre.querySelector('code');
      if (!code) return;
      navigator.clipboard.writeText(code.textContent || '').then(() => {
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 1500);
      });
    });
    pre.appendChild(btn);
  });
</script>
